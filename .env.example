# OpenGriffin configuration. Copy to .env and fill in.

# ===== Provider selection =====
# Pick ONE backend. Default `claude` uses Claude Agent SDK (full features).
# Users can override per-chat via the /model command in Telegram.
OPENGRIFFIN_PROVIDER=claude
# Options: claude, anthropic, openai, gemini, deepseek, openrouter, azure,
#          xai, mistral, cohere, perplexity, together, groq, fireworks,
#          cerebras, nvidia, huggingface, bedrock, ollama, lambda, novita, custom
OPENGRIFFIN_MODEL=
# (leave blank to use the provider's default model; set to override)

# ===== Provider keys — BYO any of these =====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
HUGGINGFACE_API_KEY=
LAMBDA_API_KEY=
NOVITA_API_KEY=

# Azure
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Custom OpenAI-compatible endpoint
CUSTOM_API_KEY=
CUSTOM_BASE_URL=

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to message the bot. Leave blank for open.
TELEGRAM_ALLOWED_USERS=
# Default chat for cron deliveries and proactive messages.
TELEGRAM_HOME_CHANNEL=

# ===== Optional features =====
# FAL.ai for image generation tool
FAL_KEY=
# Webhook gateway port
WEBHOOK_PORT=8645
# Disable Playwright MCP (set to 1 if you don't want browser automation)
CLAUDE_BOT_DISABLE_PLAYWRIGHT=
